<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CRE Rent Calculator - JLL</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .calculator-container {
            background: white;
            border-radius: 12px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
            padding: 40px;
            max-width: 500px;
            width: 100%;
        }

        .header {
            text-align: center;
            margin-bottom: 30px;
        }

        .header h1 {
            color: #333;
            font-size: 28px;
            margin-bottom: 5px;
        }

        .header p {
            color: #666;
            font-size: 14px;
        }

        .jll-logo {
            color: #0066cc;
            font-weight: bold;
            font-size: 12px;
            margin-top: 5px;
        }

        .disclaimer {
            background: #fff3cd;
            border: 1px solid #ffeaa7;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 25px;
            font-size: 12px;
            color: #856404;
            line-height: 1.4;
        }

        .disclaimer h4 {
            margin-bottom: 8px;
            color: #b8860b;
            font-size: 13px;
        }

        .input-group {
            margin-bottom: 20px;
        }

        .input-group label {
            display: block;
            margin-bottom: 8px;
            color: #333;
            font-weight: 500;
            font-size: 14px;
        }

        .input-group input {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid #e1e5e9;
            border-radius: 8px;
            font-size: 16px;
            transition: border-color 0.3s ease;
        }

        .input-group input:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        .calculate-btn {
            width: 100%;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            padding: 15px;
            font-size: 16px;
            font-weight: 600;
            border-radius: 8px;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            margin: 20px 0;
        }

        .calculate-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(102, 126, 234, 0.3);
        }

        .results {
            background: #f8f9fa;
            border-radius: 8px;
            padding: 25px;
            margin-top: 20px;
            border-left: 4px solid #667eea;
        }

        .results h3 {
            color: #333;
            margin-bottom: 15px;
            font-size: 18px;
        }

        .result-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            border-bottom: 1px solid #e1e5e9;
        }

        .result-item:last-child {
            border-bottom: none;
        }

        .result-label {
            color: #666;
            font-weight: 500;
        }

        .result-value {
            color: #333;
            font-weight: 600;
            font-size: 16px;
        }

        .hidden {
            display: none;
        }

        .error {
            background: #fee;
            border-left-color: #e74c3c;
            color: #c0392b;
        }

        .footer-disclaimer {
            margin-top: 25px;
            padding: 15px;
            background: #f8f9fa;
            border-radius: 8px;
            font-size: 11px;
            color: #666;
            line-height: 1.3;
            text-align: center;
            border-top: 1px solid #e1e5e9;
        }

        @media (max-width: 480px) {
            .calculator-container {
                padding: 20px;
                margin: 10px;
            }
            
            .header h1 {
                font-size: 24px;
            }

            .disclaimer {
                font-size: 11px;
            }

            .footer-disclaimer {
                font-size: 10px;
            }
        }
    </style>
</head>
<body>
    <div class="calculator-container">
        <div class="header">
            <h1>CRE Rent Calculator</h1>
            <p>Calculate your total commercial real estate costs</p>
            <div class="jll-logo">Powered by JLL Technologies</div>
        </div>

        <div class="disclaimer">
            <h4>⚠️ Important Disclaimer</h4>
            <strong>ESTIMATES ONLY:</strong> This calculator provides rough estimates for planning purposes only. Actual rental costs may vary significantly based on lease terms, market conditions, additional fees, and other factors not accounted for in this tool. Always consult with qualified real estate professionals and review actual lease documents for accurate financial commitments.
        </div>

        <form id="rentCalculator">
            <div class="input-group">
                <label for="baseRent">Base Rent ($ per sq ft annually)</label>
                <input type="number" id="baseRent" step="0.01" min="0" placeholder="e.g., 25.00" required>
            </div>

            <div class="input-group">
                <label for="opEx">Operating Expenses ($ per sq ft annually)</label>
                <input type="number" id="opEx" step="0.01" min="0" placeholder="e.g., 8.50" required>
            </div>

            <div class="input-group">
                <label for="sqFootage">Square Footage</label>
                <input type="number" id="sqFootage" step="1" min="1" placeholder="e.g., 5000" required>
            </div>

            <button type="submit" class="calculate-btn">Calculate Total Rent</button>
        </form>

        <div id="results" class="results hidden">
            <h3>Total Rent Calculation</h3>
            <div class="result-item">
                <span class="result-label">Total Cost Per Sq Ft:</span>
                <span class="result-value" id="costPerSqFt">$0.00</span>
            </div>
            <div class="result-item">
                <span class="result-label">Annual Total Rent:</span>
                <span class="result-value" id="annualRent">$0.00</span>
            </div>
            <div class="result-item">
                <span class="result-label">Monthly Total Rent:</span>
                <span class="result-value" id="monthlyRent">$0.00</span>
            </div>
        </div>

        <div class="footer-disclaimer">
            <strong>LEGAL DISCLAIMER:</strong> This calculator is provided "as is" for informational purposes only. JLL and its affiliates make no representations or warranties of any kind, express or implied, about the completeness, accuracy, reliability, or suitability of the information or calculations provided. Users assume all risks and liability for the use of this tool. JLL shall not be liable for any direct, indirect, incidental, consequential, or punitive damages arising from the use of this calculator. This tool does not constitute professional advice, and users should consult with qualified professionals before making any financial or real estate decisions. By using this calculator, you agree to these terms.
        </div>
    </div>

    <script>
        document.getElementById('rentCalculator').addEventListener('submit', function(e) {
            e.preventDefault();
            
            // Get input values
            const baseRent = parseFloat(document.getElementById('baseRent').value);
            const opEx = parseFloat(document.getElementById('opEx').value);
            const sqFootage = parseFloat(document.getElementById('sqFootage').value);
            
            // Validate inputs
            if (isNaN(baseRent) || isNaN(opEx) || isNaN(sqFootage)) {
                showError('Please enter valid numbers for all fields.');
                return;
            }
            
            if (baseRent < 0 || opEx < 0 || sqFootage <= 0) {
                showError('Please enter positive values. Square footage must be greater than 0.');
                return;
            }
            
            // Calculate results
            const totalCostPerSqFt = baseRent + opEx;
            const annualTotalRent = totalCostPerSqFt * sqFootage;
            const monthlyTotalRent = annualTotalRent / 12;
            
            // Display results
            document.getElementById('costPerSqFt').textContent = `$${totalCostPerSqFt.toFixed(2)}`;
            document.getElementById('annualRent').textContent = `$${annualTotalRent.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
            document.getElementById('monthlyRent').textContent = `$${monthlyTotalRent.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
            
            // Show results
            const resultsDiv = document.getElementById('results');
            resultsDiv.classList.remove('hidden', 'error');
            resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        });
        
        function showError(message) {
            const resultsDiv = document.getElementById('results');
            resultsDiv.innerHTML = `
                <h3>Error</h3>
                <div class="result-item">
                    <span class="result-value">${message}</span>
                </div>
            `;
            resultsDiv.classList.remove('hidden');
            resultsDiv.classList.add('error');
        }
        
        // Real-time input formatting and validation
        document.querySelectorAll('input[type="number"]').forEach(input => {
            input.addEventListener('input', function() {
                // Remove error styling when user starts typing
                const resultsDiv = document.getElementById('results');
                if (resultsDiv.classList.contains('error')) {
                    resultsDiv.classList.add('hidden');
                    resultsDiv.classList.remove('error');
                }
            });
        });
    </script>
</body>
</html>
