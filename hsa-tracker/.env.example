# HSA Tracker Configuration
# Copy this file to .env and fill in your values

# Microsoft Azure AD App Registration
# Register your app at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here
AZURE_TENANT_ID=your-tenant-id-here

# Optional: Specific email address to scan (defaults to authenticated user)
OUTLOOK_EMAIL=

# Flask Configuration
FLASK_SECRET_KEY=generate-a-secure-random-key-here
FLASK_DEBUG=True

# Database path (relative to app root)
DATABASE_PATH=data/hsa_tracker.db
